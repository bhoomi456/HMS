<h2>Doctors List</h2>

<table border="1" cellpadding="10" cellspacing="0" width="100%">
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Specialization</th>
      <th>Experince</th>
      <th>Status</th>
      <th>Action</th>
    </tr>
  </thead>

  <tbody>
    <% @doctors.each do |doctor| %>
      <tr>
        <td><%= doctor[:id] %></td>
        <td><%= doctor[:name] %></td>
        <td><%= doctor[:specialization] %></td>
        <td><%= doctor[:experience] %></td>
        <td><%= doctor[:available] %></td>
        <td><%= link_to "Show", "/doctors/#{doctor[:id]}" %></td>
      </tr>
    <% end %>
  </tbody>
</table>